# ---------- App ----------
APP_NAME=EazyDoctor
ENVIRONMENT=development
PORT=8000
JWT_SECRET=change_this_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------- Database (Supabase Postgres today, AWS RDS tomorrow) ----------
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/eazydoctor

# ---------- Redis (rate limiting, caching, celery broker) ----------
REDIS_URL=redis://localhost:6379/0

# ---------- Storage (Cloudinary today, S3/R2 tomorrow) ----------
STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------- Notifications (Firebase) ----------
FIREBASE_CREDENTIALS_JSON=
FIREBASE_DATABASE_URL=

# ---------- Payments (Paytm - pending approval) ----------
PAYMENT_PROVIDER=cash_only
PAYTM_MERCHANT_ID=
PAYTM_MERCHANT_KEY=
PAYTM_WEBSITE=WEBSTAGING
PAYTM_CALLBACK_URL=

# ---------- Payouts (Paytm Payout API - future) ----------
PAYTM_PAYOUT_MERCHANT_ID=
PAYTM_PAYOUT_KEY=

# ---------- Business config defaults (overridable via Admin panel / DB) ----------
DEFAULT_BOOKING_FEE=10
DEFAULT_PLATFORM_COMMISSION_PERCENT=35
DEFAULT_CANCELLATION_DEDUCTION_PERCENT=20
CANCELLATION_LOCK_HOURS=5
QUEUE_STALL_MINUTES=15
MIN_WITHDRAWAL_AMOUNT=200
